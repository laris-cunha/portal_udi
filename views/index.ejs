<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body class="bg-light">
    <!--MENU-->
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <div class="container-logo">
          <h1 class="navbar-brand" href="/">BOOOOKS</h1>
          <img src="../images/fantasma.png" alt="Logo" class="logo-animada">
        </div>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
          <div class="navbar-nav">
            <a class="nav-link active" href="/">HOME</a>
            <a class="nav-link" href="/cadastrar">CADASTRAR LIVRO</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <h1><%= title %></h1>
      
      <!--LISTA LIVROS-->
      <div class="col-md-12">
        <h4 class="mb-3">Lista de Livros</h4>
        <div class="row">
          <% livros.forEach(livro => { %>
            <div class="col-md-4 mb-4">
              <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                  <h5 class="card-title mb-0"><%= livro.titulo %></h5>
                </div>
                <div class="card-body">
                  <div class="text-center mb-3">
                    <img src="<%= livro.capa %>" alt="Capa do livro" class="capa-livro">
                  </div>
                  <p class="card-text"><strong>Autor:</strong> <%= livro.autor %></p>
                  <p class="card-text"><strong>Gênero:</strong> <%= livro.genero %></p>
                  <a href="/detalhar/<%= livro.id %>" class="btn btn-primary btn-sm mt-2">🔍 Ver Detalhes</a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>