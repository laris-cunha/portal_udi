<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <!--MENU-->
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">📚 Portal do Livro</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
          <div class="navbar-nav">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/cadastrar">Cadastrar Livro</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="container mt-5">
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="detalhes-card">
            <div class="detalhes-header bg-primary text-white">
              <h3 class="mb-0">📖 Detalhes do Livro</h3>
              <p class="mb-0 mt-2">Informações completas sobre a obra</p>
            </div>
            <div class="card-body p-4">
              <div class="info-row">
                <div class="info-label">ID do Livro:</div>
                <div class="info-value">
                  <span class="badge bg-secondary"><%= livro.id %></span>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">📖 Título:</div>
                <div class="info-value">
                  <strong><%= livro.titulo %></strong>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">✍️ Autor:</div>
                <div class="info-value"><%= livro.autor %></div>
              </div>
              
              <div class="info-row">
                <div class="info-label">📚 Gênero:</div>
                <div class="info-value">
                  <span class="badge-genero"><%= livro.genero %></span>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">📅 Ano de Publicação:</div>
                <div class="info-value"><%= livro.ano %></div>
              </div>
              
              <div class="info-row">
                <div class="info-label">🕒 Data de Cadastro:</div>
                <div class="info-value">
                  <%= new Date(livro.data_cadastro).toLocaleDateString('pt-BR') %> às 
                  <%= new Date(livro.data_cadastro).toLocaleTimeString('pt-BR') %>
                </div>
              </div>
            </div>
            <div class="card-footer bg-white border-top-0 p-4">
              <div class="d-flex justify-content-between">
                <a href="/cadastrar" class="btn-editar">➕ Cadastrar Novo Livro</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>