<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">
  </head>
  <body>
    <!--MENU-->
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <div class="container-logo">
          <h1 class="navbar-brand" href="/">BOOOOKS</h1>
          <img src="../images/fantasma.png" alt="Logo" class="logo-animada">
        </div>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
          <div class="navbar-nav">
            <a class="nav-link" href="/">HOME</a>
            <a class="nav-link" href="/cadastrar">CADASTRAR LIVRO</a>
            <a class="nav-link active" href="#">DETALHES DO LIVRO</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="container mt-5">
      <div class="row justify-content-center">
        <!--INFORMAÇÕES DO LIVRO -->
        <div class="col-md-7">
          <div class="detalhes-card">
            <div class="detalhes-header bg-primary text-white">
              <h3 class="mb-0">Detalhes do Livro</h3>
              <p class="mb-0 mt-2">Informações completas sobre a obra</p>
            </div>
            <div class="card-body p-4">
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/id-icon.png" alt="Logo" class="logo-label">
                  <h4>ID do Livro:</h4>
                </div>
                <div class="info-value">
                  <span class="badge bg-secondary">#00<%= livro.id %>LI</span>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/titulo-icon.png" alt="Logo" class="logo-label">
                  <h4>Título:</h4>
                </div>
                <div class="info-value">
                  <span class="info-value"><%= livro.titulo %></span>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/autor-icon.png" alt="Logo" class="logo-label">
                  <h4>Autor:</h4>
                </div>
                <div class="info-value"><%= livro.autor %></div>
              </div>
              
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/genero-icon.png" alt="Logo" class="logo-label">
                  <h4>Gênero:</h4>
                </div>
                <div class="info-value">
                  <span class="badge-genero"><%= livro.genero %></span>
                </div>
              </div>
              
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/publicacao-icon.png" alt="Logo" class="logo-label">
                  <h4>Ano de Publicação:</h4>
                </div>
                <div class="info-value"><%= livro.ano %></div>
              </div>
              
              <div class="info-row">
                <div class="info-label">
                  <img src="../images/cadastro-icon.png" alt="Logo" class="logo-label">
                  <h4>Data de Cadastro:</h4>
                </div>
                <div class="info-value">
                  <%= new Date(livro.data_cadastro).toLocaleDateString('pt-BR') %> às 
                  <%= new Date(livro.data_cadastro).toLocaleTimeString('pt-BR') %>
                </div>
              </div>
            </div>
            <div class="card-footer bg-white border-top-0 p-4">
              <div class="d-flex justify-content-between">
                <a href="/" class="btn-voltar">
                  <img src="../images/voltar.png" alt="Seta Voltar">
                  VOLTAR
                </a>
                <a href="/editar/<%= livro.id %>" class="btn btn-primary btn-cadastro">
                  <img src="../images/validar-cadastro.png" alt="Ícone Editar">
                  EDITAR LIVRO
                </a>
              </div>
            </div>
          </div>
        </div>
        <!-- CAPA DO LIVRO -->
        <div class="col-md-5 d-flex">
          <div class="detalhes-card text-center w-100">
            <div class="detalhes-header bg-primary text-white capa-header">
              <h3 class="mb-0">Capa do Livro</h3>
            </div>
            <div class="card-body p-4 capa-livro-detalhar">
              <img src="<%= livro.capa %>" alt="Capa do livro <%= livro.titulo %>" class="img-fluid rounded shadow-sm">
            </div>
          </div>
        </div>

      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>